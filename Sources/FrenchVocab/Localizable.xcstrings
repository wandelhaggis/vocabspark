    "Hol dir einen Key unter platform.openai.com/api-keys\nDer Key bleibt nur auf diesem Gerät gespeichert." : {
      "comment" : "SettingsView.swift:93",
      "extractionState" : "manual",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "احصل على مفتاح من platform.openai.com/api-keys\nالمفتاح يُحفظ على هذا الجهاز فقط."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Hol dir einen Key unter platform.openai.com/api-keys\nDer Key bleibt nur auf diesem Gerät gespeichert."
          }
        },
        "el" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Πάρε ένα Key από το platform.openai.com/api-keys\nΤο Key αποθηκεύεται μόνο σε αυτή τη συσκευή."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Get a key at platform.openai.com/api-keys\nIt's stored only on this device."
