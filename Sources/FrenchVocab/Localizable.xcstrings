    "Hol dir einen Key unter platform.openai.com/api-keys\nDer Key bleibt nur auf diesem Gerät gespeichert.": {
      "comment": "SettingsView.swift:93",
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Hol dir einen Key unter platform.openai.com/api-keys\nDer Key bleibt nur auf diesem Gerät gespeichert."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Get a key at platform.openai.com/api-keys\nIt's stored only on this device."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Obtiens une clé sur platform.openai.com/api-keys\nLa clé reste uniquement sur cet appareil."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Consigue una clave en platform.openai.com/api-keys\nLa clave se guarda solo en este dispositivo."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Ottieni una chiave su platform.openai.com/api-keys\nLa chiave rimane solo su questo dispositivo."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Vai buscar uma chave a platform.openai.com/api-keys\nA chave fica guardada apenas neste dispositivo."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Haal een sleutel op bij platform.openai.com/api-keys\nDe sleutel wordt alleen op dit apparaat bewaard."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Hämta en nyckel på platform.openai.com/api-keys\nNyckeln sparas bara på den här enheten."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Pobierz klucz ze strony platform.openai.com/api-keys\nKlucz zostaje tylko na tym urządzeniu."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Получи ключ на platform.openai.com/api-keys\nКлюч хранится только на этом устройстве."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Anahtarı platform.openai.com/api-keys adresinden al\nAnahtar sadece bu cihazda saklanır."
          }
        },
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Πάρε ένα Key από το platform.openai.com/api-keys\nΤο Key αποθηκεύεται μόνο σε αυτή τη συσκευή."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "platform.openai.com/api-keys でキーを取得できます。\nキーはこの端末にのみ保存されます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "platform.openai.com/api-keys 에서 키를 받으세요\n키는 이 기기에만 저장돼요."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "请前往 platform.openai.com/api-keys 获取密钥\n密钥仅保存在此设备上。"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "احصل على مفتاح من platform.openai.com/api-keys\nالمفتاح يُحفظ على هذا الجهاز فقط."
          }
        }
      }
    },
