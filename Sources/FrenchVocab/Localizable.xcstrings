        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Consigue una clave en platform.openai.com/api-keys\nLa clave se guarda solo en este dispositivo."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
