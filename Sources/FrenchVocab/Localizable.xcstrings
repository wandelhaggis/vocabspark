    "Für Aussprache und Beispielsätze brauchst du einen OpenAI API-Key. Du kannst ihn in den Einstellungen eingeben.": {
      "comment": "ContentView.swift:52",
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Für Aussprache und Beispielsätze brauchst du einen OpenAI API-Key. Du kannst ihn in den Einstellungen eingeben."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "For pronunciation and example sentences you need an OpenAI API key. You can enter it in Settings."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Pour la prononciation et les exemples, il te faut une clé API OpenAI. Tu peux la saisir dans les Réglages."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Para la pronunciación y las frases de ejemplo necesitas una clave API de OpenAI. Puedes introducirla en los Ajustes."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Per la pronuncia e gli esempi ti serve una chiave API OpenAI. Puoi inserirla nelle Impostazioni."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Para a pronúncia e frases de exemplo precisas de uma chave da OpenAI. Podes introduzi-la nas Definições."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Voor uitspraak en voorbeeldzinnen heb je een OpenAI API-sleutel nodig. Je kunt die in de instellingen invoeren."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "För uttal och exempelmeningar behöver du en OpenAI API-nyckel. Du kan ange den i inställningarna."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Do wymowy i przykładowych zdań potrzebujesz klucza API OpenAI. Możesz go wpisać w ustawieniach."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Для произношения и примеров нужен API-ключ OpenAI. Ты можешь ввести его в настройках."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Telaffuz ve örnek cümleler için bir OpenAI API anahtarına ihtiyacın var. Anahtarı Ayarlar'dan girebilirsin."
          }
        },
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Για την προφορά και τα παραδείγματα χρειάζεσαι ένα OpenAI API Key. Μπορείς να το εισάγεις στις ρυθμίσεις."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "発音と例文を使うには OpenAI APIキーが必要です。設定から入力できます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "발음과 예문을 사용하려면 OpenAI API 키가 필요해요. 설정에서 입력할 수 있어요."
          }
