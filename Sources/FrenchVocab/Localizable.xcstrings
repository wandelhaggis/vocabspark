          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "platform.openai.com/api-keys でキーを取得できます。\nキーはこの端末にのみ保存されます。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "platform.openai.com/api-keys 에서 키를 받으세요\n키는 이 기기에만 저장돼요."
